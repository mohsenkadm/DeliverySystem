@model DeliverySystem.Application.DTOs.TransferOrderDto
@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = $"طلب نقل {Model.OrderNumber}";
}

<div class="page-header mb-4" data-aos="fade-down">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
        <i class="fas fa-arrow-right me-1"></i>العودة للقائمة
    </a>
    <h4><i class="fas fa-exchange-alt me-2 text-primary"></i>@Model.OrderNumber</h4>
</div>

<div class="row g-4">
    <!-- Info Card -->
    <div class="col-md-4" data-aos="fade-up">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>معلومات الطلب</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">النوع</dt>
                    <dd class="col-7"><span class="badge bg-primary">@Model.OrderTypeText</span></dd>
                    <dt class="col-5">الحالة</dt>
                    <dd class="col-7"><span class="badge bg-info">@Model.StatusText</span></dd>
                    <dt class="col-5">من مستودع</dt>
                    <dd class="col-7">@Model.FromWarehouseName</dd>
                    <dt class="col-5">إلى مستودع</dt>
                    <dd class="col-7">@Model.ToWarehouseName</dd>
                    <dt class="col-5">طلبه</dt>
                    <dd class="col-7">@Model.RequestedByEmployeeName</dd>
                    <dt class="col-5">وافق عليه</dt>
                    <dd class="col-7">@(Model.ApprovedByEmployeeName ?? "—")</dd>
                    <dt class="col-5">تاريخ الطلب</dt>
                    <dd class="col-7">@Model.RequestedAt.ToString("yyyy/MM/dd HH:mm")</dd>
                    @if (Model.ApprovedAt.HasValue)
                    {
                        <dt class="col-5">تاريخ الموافقة</dt>
                        <dd class="col-7">@Model.ApprovedAt.Value.ToString("yyyy/MM/dd")</dd>
                    }
                    @if (Model.CompletedAt.HasValue)
                    {
                        <dt class="col-5">تاريخ الإكمال</dt>
                        <dd class="col-7">@Model.CompletedAt.Value.ToString("yyyy/MM/dd")</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <dt class="col-5">ملاحظات</dt>
                        <dd class="col-7">@Model.Notes</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- Actions + Items -->
    <div class="col-md-8" data-aos="fade-up">
        <!-- Workflow Actions -->
        @if (Model.Status == TransferOrderStatus.Pending)
        {
            <div class="alert alert-warning mb-3">
                <strong>بانتظار موافقة المحاسب</strong>
                <div class="mt-2 d-flex gap-2">
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-success btn-sm" onclick="return confirm('الموافقة على الطلب وإحالته للمستودع؟')">
                            <i class="fas fa-check me-1"></i>الموافقة
                        </button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-danger btn-sm" onclick="return confirm('رفض هذا الطلب؟')">
                            <i class="fas fa-times me-1"></i>الرفض
                        </button>
                    </form>
                </div>
            </div>
        }
        @if (Model.Status == TransferOrderStatus.AccountantApproved)
        {
            <div class="alert alert-info mb-3">
                <strong>موافقة المحاسب — بانتظار المستودع</strong>
                <div class="mt-2">
                    <form asp-action="StartProcessing" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-warning btn-sm">
                            <i class="fas fa-cogs me-1"></i>بدء التجهيز في المستودع
                        </button>
                    </form>
                </div>
            </div>
        }
        @if (Model.Status == TransferOrderStatus.WarehouseProcessing)
        {
            <div class="alert alert-primary mb-3">
                <strong>المستودع يجهز الطلب</strong>
                <div class="mt-2">
                    <form asp-action="Complete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-success btn-sm" onclick="return confirm('إكمال النقل؟ سيتم تحديث المخزون في كلا المستودعين.')">
                            <i class="fas fa-check-double me-1"></i>إكمال النقل وتحديث المخزون
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Items Table -->
        <div class="card">
            <div class="card-header"><i class="fas fa-boxes me-2"></i>الأصناف (@Model.Details.Count)</div>
            <div class="card-body p-0">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>المنتج</th>
                            <th class="text-center">الكمية المطلوبة</th>
                            <th class="text-center">الكمية المعتمدة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Details)
                        {
                            <tr>
                                <td>@d.ProductName</td>
                                <td class="text-center">@d.RequestedQuantity</td>
                                <td class="text-center">@(d.ApprovedQuantity?.ToString() ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
