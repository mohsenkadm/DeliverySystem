@model IEnumerable<DeliverySystem.Application.DTOs.TransferOrderDto>
@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = "طلبات النقل بين المستودعات";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1"><i class="fas fa-exchange-alt me-2 text-primary"></i>طلبات النقل</h4>
        <p class="text-muted mb-0">إدارة نقل البضاعة بين المستودعات</p>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4" data-aos="fade-up">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <select name="status" class="form-select" onchange="this.form.submit()">
                    @foreach (SelectListItem item in ViewBag.StatusList)
                    {
                        <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="type" class="form-select" onchange="this.form.submit()">
                    <option value="">جميع الأنواع</option>
                    <option value="0" selected="@(ViewBag.TypeFilter==TransferOrderType.OutboundToRepWarehouse?"selected":null)">إرسال لمستودع المندوب</option>
                    <option value="1" selected="@(ViewBag.TypeFilter==TransferOrderType.ReturnToMainWarehouse?"selected":null)">إرجاع للمستودع الرئيسي</option>
                </select>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card" data-aos="fade-up">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>رقم الطلب</th>
                        <th>النوع</th>
                        <th>من مستودع</th>
                        <th>إلى مستودع</th>
                        <th>المندوب</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td><code>@o.OrderNumber</code></td>
                            <td>
                                <span class="badge @(o.OrderType == TransferOrderType.OutboundToRepWarehouse ? "bg-primary" : "bg-warning text-dark")">
                                    @o.OrderTypeText
                                </span>
                            </td>
                            <td>@o.FromWarehouseName</td>
                            <td>@o.ToWarehouseName</td>
                            <td>@o.RequestedByEmployeeName</td>
                            <td>
                                <span class="badge @StatusBadge(o.Status)">@o.StatusText</span>
                            </td>
                            <td>@o.RequestedAt.ToString("yyyy/MM/dd")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (o.Status == TransferOrderStatus.Pending)
                                {
                                    <form asp-action="Approve" asp-route-id="@o.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success ms-1" onclick="return confirm('موافقة على هذا الطلب؟')">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Reject" asp-route-id="@o.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger ms-1" onclick="return confirm('رفض هذا الطلب؟')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }
                                @if (o.Status == TransferOrderStatus.AccountantApproved)
                                {
                                    <form asp-action="StartProcessing" asp-route-id="@o.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-warning ms-1">
                                            <i class="fas fa-cogs"></i> بدء التجهيز
                                        </button>
                                    </form>
                                }
                                @if (o.Status == TransferOrderStatus.WarehouseProcessing)
                                {
                                    <form asp-action="Complete" asp-route-id="@o.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success ms-1" onclick="return confirm('إكمال النقل وتحديث المخزون؟')">
                                            <i class="fas fa-check-double"></i> إكمال
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">لا توجد طلبات نقل</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    static string StatusBadge(TransferOrderStatus s) => s switch
    {
        TransferOrderStatus.Pending             => "bg-secondary",
        TransferOrderStatus.AccountantApproved  => "bg-info",
        TransferOrderStatus.WarehouseProcessing => "bg-warning text-dark",
        TransferOrderStatus.Completed           => "bg-success",
        TransferOrderStatus.Rejected            => "bg-danger",
        _                                       => "bg-secondary"
    };
}
