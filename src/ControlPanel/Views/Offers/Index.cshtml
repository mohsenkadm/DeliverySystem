@model IEnumerable<OfferDto>
@using DeliverySystem.Application.DTOs
@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = "إدارة العروض";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-tags"></i> إدارة العروض والخصومات</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>إضافة عرض</a>
</div>

<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="اسم العرض أو كود البروموكود..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="isActive" class="form-select">
                    <option value="">-- جميع الحالات --</option>
                    <option value="true"  selected="@(ViewBag.IsActive!=null&&(bool)ViewBag.IsActive==true?"selected":null)">نشط</option>
                    <option value="false" selected="@(ViewBag.IsActive!=null&&(bool)ViewBag.IsActive==false?"selected":null)">غير نشط</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>تطبيق</button>
            </div>
        </form>
    </div>
</div>

<div class="card" data-aos="fade-up">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>قائمة العروض</span>
        <span class="badge bg-primary">@Model.Count()</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>اسم العرض</th>
                        <th>المنتج</th>
                        <th>نوع العرض</th>
                        <th>القيمة</th>
                        <th>البروموكود</th>
                        <th>الفترة</th>
                        <th>الحالة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td class="fw-bold">@o.Name</td>
                            <td>@Html.Raw(o.ProductName ?? "<span class='badge bg-secondary'>جميع المنتجات</span>")</td>
                            <td>
                                @{
                                    var typeClass = o.OfferType switch {
                                        OfferType.BuyOneGetOne or OfferType.BuyOneGetTwo or OfferType.BuyOneGetThree => "bg-info",
                                        OfferType.DiscountPercentage => "bg-warning text-dark",
                                        OfferType.FixedPrice => "bg-primary",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @typeClass">@o.OfferTypeText</span>
                            </td>
                            <td>
                                @if (o.OfferType is OfferType.DiscountPercentage)
                                { <span>@o.DiscountValue%</span> }
                                else if (o.OfferType is OfferType.FixedPrice)
                                { <span>@o.DiscountValue د.ع</span> }
                                else if (o.FreeQuantity.HasValue)
                                { <span>+@o.FreeQuantity مجاني</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(o.PromoCode))
                                { <code class="badge bg-dark">@o.PromoCode</code> }
                                else { <span class="text-muted">تلقائي</span> }
                            </td>
                            <td class="small">
                                @(o.StartDate?.ToString("yyyy/MM/dd") ?? "—") - @(o.EndDate?.ToString("yyyy/MM/dd") ?? "مفتوح")
                            </td>
                            <td>
                                @if (o.IsCurrentlyValid)
                                { <span class="badge bg-success"><i class="fas fa-check me-1"></i>نشط</span> }
                                else if (o.IsActive && o.StartDate > DateTime.Now)
                                { <span class="badge bg-info">قادم</span> }
                                else
                                { <span class="badge bg-secondary">غير نشط</span> }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-outline-warning btn-action"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Toggle" asp-route-id="@o.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(o.IsActive?"btn-outline-secondary":"btn-outline-success") btn-action"
                                                title="@(o.IsActive?"تعطيل":"تفعيل")">
                                            <i class="fas @(o.IsActive?"fa-toggle-off":"fa-toggle-on")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@o.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('حذف العرض @o.Name؟')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-action"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-5">
                            <i class="fas fa-tags fa-3x mb-3 d-block opacity-25"></i>لا توجد عروض
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
