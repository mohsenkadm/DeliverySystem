@model CreateRepresentativeDto
@{
    ViewData["Title"] = "إضافة مندوب جديد";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-user-tie"></i> إضافة مندوب جديد</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card" data-aos="fade-up">
            <div class="card-header"><i class="fas fa-user-tie"></i> بيانات المندوب</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label">الاسم الكامل <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="الاسم الكامل" required />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">رقم الهاتف <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" placeholder="05XXXXXXXX" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label">اسم المستخدم <span class="text-danger">*</span></label>
                            <input asp-for="Username" class="form-control" placeholder="username" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label">كلمة المرور <span class="text-danger">*</span></label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">العنوان</label>
                            <input asp-for="Address" class="form-control" placeholder="العنوان" />
                        </div>
                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>حفظ</button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">إلغاء</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
