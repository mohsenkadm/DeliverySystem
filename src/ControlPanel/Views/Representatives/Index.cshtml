@model IEnumerable<RepresentativeDto>
@{
    ViewData["Title"] = "إدارة المندوبين";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-user-tie"></i> إدارة المندوبين</h1>
    <div class="d-flex gap-2 no-print">
        <a asp-action="ExportExcel" class="btn btn-outline-success btn-sm"><i class="fas fa-file-excel me-1"></i>تصدير</a>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>إضافة مندوب</a>
    </div>
</div>

<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label">بحث</label>
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="الاسم أو الهاتف..." />
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>بحث</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var r in Model)
    {
        <div class="col-xl-4 col-md-6" data-aos="fade-up">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="avatar-circle" style="width:50px;height:50px;font-size:20px">@r.FullName.Substring(0,1)</div>
                        <div>
                            <h5 class="mb-0 fw-bold">@r.FullName</h5>
                            <small class="text-muted">@r.Phone</small>
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-4 text-center">
                            <div class="fw-bold text-primary fs-5">@r.CustomerCount</div>
                            <small class="text-muted">عملاء</small>
                        </div>
                        <div class="col-4 text-center">
                            <div class="fw-bold text-success fs-5">@String.Format("{0:N0}", r.TotalCollected)</div>
                            <small class="text-muted">محصّل</small>
                        </div>
                        <div class="col-4 text-center">
                            <div class="fw-bold text-danger fs-5">@String.Format("{0:N0}", r.TotalDebt)</div>
                            <small class="text-muted">ديون</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="fas fa-eye me-1"></i>تفاصيل
                        </a>
                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-warning btn-sm btn-action"><i class="fas fa-edit"></i></a>
                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline"
                              onsubmit="return confirm('حذف المندوب @r.FullName؟')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm btn-action"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="fas fa-user-tie fa-3x mb-3 d-block opacity-25"></i>لا توجد مندوبين
        </div>
    }
</div>
