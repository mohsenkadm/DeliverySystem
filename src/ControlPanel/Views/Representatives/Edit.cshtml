@model UpdateRepresentativeDto
@{
    ViewData["Title"] = "تعديل بيانات المندوب";
    var repId = ViewBag.RepId;
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-edit"></i> تعديل بيانات المندوب</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-user-tie"></i> بيانات المندوب</div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@repId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">رقم الهاتف</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Address" class="form-label">العنوان</label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>حفظ التعديلات</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
