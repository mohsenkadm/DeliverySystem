@model IEnumerable<CustomerDto>
@using DeliverySystem.Application.DTOs
@{
    ViewData["Title"] = "إدارة العملاء";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-users"></i> إدارة العملاء</h1>
    <div class="d-flex gap-2 no-print flex-wrap">
        <a asp-action="ExportExcel" class="btn btn-success btn-sm"><i class="fas fa-file-excel me-1"></i>تصدير Excel</a>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-user-plus me-1"></i>إضافة عميل</a>
    </div>
</div>

<!-- فلاتر -->
<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted">بحث</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="الاسم، اسم المتجر، الهاتف..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">المندوب</label>
                <select name="empId" class="form-select">
                    <option value="">-- جميع المندوبين --</option>
                    @if (ViewBag.Employees != null)
                    {
                        foreach (var e in ViewBag.Employees)
                        { <option value="@e.Id" selected="@(ViewBag.EmpId!=null && (int)ViewBag.EmpId==e.Id?"selected":null)">@e.FullName</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">حالة الموافقة</label>
                <select name="isApproved" class="form-select">
                    <option value="">-- الجميع --</option>
                    <option value="true"  selected="@(ViewBag.IsApproved!=null&&(bool)ViewBag.IsApproved==true ?"selected":null)">موافق عليه</option>
                    <option value="false" selected="@(ViewBag.IsApproved!=null&&(bool)ViewBag.IsApproved==false?"selected":null)">في الانتظار</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>تطبيق</button>
            </div>
        </form>
    </div>
</div>

<!-- جدول العملاء -->
<div class="card" data-aos="fade-up">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>قائمة العملاء</span>
        <span class="badge bg-primary">@Model.Count()</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>العميل</th>
                        <th>الهاتف</th>
                        <th>النوع</th>
                        <th>المنطقة</th>
                        <th>المندوب</th>
                        <th>الفواتير</th>
                        <th>الديون</th>
                        <th>الحالة</th>
                        <th class="no-print">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(c.StoreImagePath))
                                    { <img src="@c.StoreImagePath" class="rounded-circle" style="width:34px;height:34px;object-fit:cover;" /> }
                                    else
                                    { <div class="avatar-circle" style="width:34px;height:34px;font-size:13px;">@(c.FullName.Length>0?c.FullName[0].ToString():"ع")</div> }
                                    <div>
                                        <div class="fw-bold">@c.FullName</div>
                                        @if (!string.IsNullOrEmpty(c.StoreName)) { <small class="text-primary">@c.StoreName</small> }
                                        else { <small class="text-muted">@c.Username</small> }
                                    </div>
                                </div>
                            </td>
                            <td><i class="fas fa-phone text-muted me-1"></i>@c.Phone</td>
                            <td><span class="badge @(c.ClientType=="Wholesale"?"bg-warning text-dark":"bg-primary")">@(c.ClientType=="Wholesale"?"جملة":"فرد")</span></td>
                            <td>@(c.Region ?? "—")</td>
                            <td>@(c.EmployeeName ?? "—")</td>
                            <td><span class="badge bg-info">@c.InvoiceCount</span></td>
                            <td class="@(c.TotalDebt > 0 ? "text-danger fw-bold" : "text-success")">
                                @String.Format("{0:N0}", c.TotalDebt) ر.س
                            </td>
                            <td>
                                @if (c.IsApproved)
                                { <span class="badge bg-success"><i class="fas fa-check me-1"></i>موافق</span> }
                                else
                                { <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>انتظار</span> }
                            </td>
                            <td class="no-print">
                                <div class="d-flex gap-1">
                                    @if (!c.IsApproved)
                                    {
                                        <form asp-action="Approve" asp-route-id="@c.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success btn-action" title="موافقة"><i class="fas fa-check"></i></button>
                                        </form>
                                    }
                                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info btn-action"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning btn-action"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('هل أنت متأكد من حذف هذا العميل؟')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-action"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-5"><i class="fas fa-users fa-3x mb-3 d-block opacity-25"></i>لا توجد بيانات</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
