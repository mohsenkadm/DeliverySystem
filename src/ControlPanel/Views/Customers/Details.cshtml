@model CustomerDto
@using DeliverySystem.Application.DTOs
@{
    ViewData["Title"] = "تفاصيل العميل";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-user"></i> @Model.FullName</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm no-print"><i class="fas fa-edit me-1"></i>تعديل</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    </div>
</div>

<div class="row g-4">
    <!-- بطاقة الملف الشخصي -->
    <div class="col-lg-4" data-aos="fade-up">
        <div class="card text-center">
            <div class="card-body py-4">
                @if (!string.IsNullOrEmpty(Model.StoreImagePath))
                {
                    <img src="@Model.StoreImagePath" class="rounded mb-3" style="width:110px;height:110px;object-fit:cover;border:4px solid #4f46e5;" alt="صورة المتجر" />
                }
                else
                {
                    <div class="avatar-circle mx-auto mb-3" style="width:90px;height:90px;font-size:36px;">@(Model.FullName.Length > 0 ? Model.FullName[0].ToString() : "ع")</div>
                }
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                @if (!string.IsNullOrEmpty(Model.StoreName))
                { <p class="text-primary mb-1"><i class="fas fa-store me-1"></i>@Model.StoreName</p> }
                <p class="text-muted mb-2"><i class="fas fa-phone me-1"></i>@Model.Phone</p>
                <span class="badge @(Model.ClientType == "Wholesale" ? "bg-warning text-dark" : "bg-primary") mb-3">
                    @(Model.ClientType == "Wholesale" ? "جملة" : "فرد")
                </span>
                <div class="mt-2">
                    @if (Model.IsApproved)
                    { <span class="badge bg-success fs-6"><i class="fas fa-check-circle me-1"></i>موافق عليه</span> }
                    else
                    {
                        <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="no-print">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-success btn-sm w-100"><i class="fas fa-check me-1"></i>الموافقة على الحساب</button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- إحصائيات -->
        <div class="row g-3 mt-1">
            <div class="col-6">
                <div class="stat-card success text-center py-3">
                    <div class="stat-value">@Model.InvoiceCount</div>
                    <div class="stat-label">الفواتير</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card text-center py-3">
                    <div class="stat-value">@String.Format("{0:N0}", Model.TotalPaid) <small style="font-size:11px">ر.س</small></div>
                    <div class="stat-label">المدفوع</div>
                </div>
            </div>
            <div class="col-12">
                <div class="stat-card danger text-center py-3">
                    <div class="stat-value">@String.Format("{0:N0}", Model.TotalDebt) <small style="font-size:13px">ر.س</small></div>
                    <div class="stat-label">الديون المتبقية</div>
                </div>
            </div>
        </div>
    </div>

    <!-- التفاصيل -->
    <div class="col-lg-8" data-aos="fade-up">
        <div class="card mb-4">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>المعلومات التفصيلية</div>
            <div class="card-body">
                <div class="row g-3">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12">
                            <label class="text-muted small">الوصف / ملاحظات</label>
                            <div class="p-2 bg-light rounded">@Model.Description</div>
                        </div>
                    }
                    <div class="col-md-6">
                        <label class="text-muted small">العنوان</label>
                        <div class="fw-bold"><i class="fas fa-map-marker-alt text-danger me-2"></i>@Model.Address</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Region))
                    {
                        <div class="col-md-3">
                            <label class="text-muted small">المنطقة</label>
                            <div class="fw-bold">@Model.Region</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Branch))
                    {
                        <div class="col-md-3">
                            <label class="text-muted small">الفرع</label>
                            <div class="fw-bold">@Model.Branch</div>
                        </div>
                    }
                    <div class="col-md-6">
                        <label class="text-muted small">المندوب المسؤول</label>
                        <div class="fw-bold"><i class="fas fa-user-tie text-primary me-2"></i>@(Model.EmployeeName ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">تاريخ التسجيل</label>
                        <div class="fw-bold"><i class="fas fa-calendar text-primary me-2"></i>@Model.CreatedAt.ToString("yyyy/MM/dd")</div>
                    </div>
                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        <div class="col-12">
                            <label class="text-muted small">الموقع الجغرافي</label>
                            <div class="fw-bold">
                                <i class="fas fa-crosshairs text-success me-2"></i>
                                @Model.Latitude?.ToString("F6") , @Model.Longitude?.ToString("F6")
                                <a href="https://maps.google.com/?q=@Model.Latitude,@Model.Longitude" target="_blank" class="btn btn-sm btn-outline-success ms-2">
                                    <i class="fas fa-map me-1"></i>عرض على الخريطة
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
