@model IEnumerable<CategoryDto>
@{
    ViewData["Title"] = "إدارة التصنيفات";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-tags"></i> إدارة التصنيفات</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm no-print"><i class="fas fa-plus me-1"></i>إضافة تصنيف</a>
</div>

<div class="row g-3">
    @foreach (var c in Model)
    {
        <div class="col-xl-3 col-md-4 col-sm-6" data-aos="fade-up">
            <div class="card text-center p-3 h-100">
                <div class="avatar-circle mx-auto mb-3" style="width:54px;height:54px;font-size:22px;background:linear-gradient(135deg,#4f46e5,#8b5cf6)">
                    <i class="fas fa-tag" style="font-size:18px"></i>
                </div>
                <h5 class="fw-bold mb-1">@c.Name</h5>
                <div class="text-primary mb-3 fw-bold fs-5">@c.ProductCount <small class="text-muted fs-6">منتج</small></div>
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-warning btn-sm"><i class="fas fa-edit me-1"></i>تعديل</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post"
                          onsubmit="return confirm('حذف تصنيف @c.Name؟')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="fas fa-tags fa-3x mb-3 d-block opacity-25"></i>لا توجد تصنيفات
        </div>
    }
</div>
