@model CreateCategoryDto
@{
    ViewData["Title"] = "تعديل التصنيف";
    var catId = ViewBag.CatId;
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-edit"></i> تعديل التصنيف</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-tags"></i> بيانات التصنيف</div>
            <div class="card-body">
                <form asp-controller="Categories" asp-action="Edit" asp-route-id="@catId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">اسم التصنيف</label>
                        <input asp-for="Name" class="form-control" autofocus />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>حفظ التعديلات</button>
                        <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
