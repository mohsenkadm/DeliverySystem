@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = "تحصيلات المندوبين";
    var payments = ViewBag.Payments as List<DeliverySystem.Domain.Entities.Payment> ?? new();
    var byRep = ViewBag.ByRep as System.Collections.IEnumerable;
}
<div class="page-header d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1"><i class="fas fa-user-tie me-2 text-success"></i>تحصيلات المندوبين</h4>
        <p class="text-muted mb-0">المبالغ المحصّلة والمسلّمة للإدارة من كل مندوب</p>
    </div>
    <div class="d-flex gap-2 no-print">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-print me-1"></i>طباعة</button>
        <button onclick="exportPDF()" class="btn btn-outline-danger btn-sm"><i class="fas fa-file-pdf me-1"></i>PDF</button>
    </div>
</div>

<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto"><label class="form-label small mb-1">من</label><input type="date" name="from" value="@ViewBag.From" class="form-control form-control-sm"/></div>
            <div class="col-auto"><label class="form-label small mb-1">إلى</label><input type="date" name="to" value="@ViewBag.To" class="form-control form-control-sm"/></div>
            <div class="col-auto">
                <label class="form-label small mb-1">المندوب</label>
                <select name="employeeId" class="form-select form-select-sm">
                    <option value="">— الكل —</option>
                    @if (ViewBag.Employees != null)
                    {
                        foreach (var e in ViewBag.Employees)
                        { <option value="@e.Id" selected="@(ViewBag.SelectedEmployee?.ToString()==e.Id.ToString())">@e.FullName</option> }
                    }
                </select>
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>تصفية</button></div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-chart-bar me-2"></i>مقارنة التحصيل مقابل التسليم</div>
            <div class="card-body"><div style="height:280px"><canvas id="repChart"></canvas></div></div>
        </div>
    </div>
    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
        <div class="card">
            <div class="card-header"><i class="fas fa-list me-2"></i>ملخص</div>
            <div class="card-body">
                @foreach (dynamic rep in byRep ?? Enumerable.Empty<object>())
                {
                    var pct = rep.Collected > 0 ? (int)Math.Round((double)rep.Submitted / rep.Collected * 100) : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1"><small class="fw-bold">@rep.Name</small><small class="text-muted">@pct%</small></div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar @(pct>=90?"bg-success":pct>=60?"bg-warning":"bg-danger")" style="width:@pct%"></div>
                        </div>
                        <small class="text-muted">حصّل: @rep.Collected.ToString("N0") / سلّم: @rep.Submitted.ToString("N0") ر.س</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card" data-aos="fade-up">
    <div class="card-header"><i class="fas fa-receipt me-2"></i>سجل التحصيلات</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light"><tr><th>التاريخ</th><th>المندوب</th><th>النوع</th><th>العميل</th><th>الفاتورة</th><th class="text-end">المبلغ</th><th>التحقق</th></tr></thead>
                <tbody>
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.PaidAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td>@(p.PaidByEmployee?.FullName ?? "—")</td>
                            <td><span class="badge @(p.Type==PaymentType.CustomerToRepresentative?"bg-info":"bg-success")">@(p.Type==PaymentType.CustomerToRepresentative?"تحصيل من عميل":"تسليم للإدارة")</span></td>
                            <td>@(p.Customer?.FullName ?? "—")</td>
                            <td>@(p.Invoice?.InvoiceNumber ?? "—")</td>
                            <td class="text-end fw-bold text-success">@p.Amount.ToString("N2") ر.س</td>
                            <td>@(p.IsVerified ? Html.Raw("<span class='badge bg-success'>✓</span>") : Html.Raw("<span class='badge bg-warning text-dark'>معلق</span>"))</td>
                        </tr>
                    }
                    @if (!payments.Any()) { <tr><td colspan="7" class="text-center py-4 text-muted">لا توجد بيانات</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
const repLabels    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepLabels    ?? new List<string>()));
const repCollected = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepCollected ?? new List<decimal>()));
const repSubmitted = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepSubmitted ?? new List<decimal>()));

new Chart(document.getElementById('repChart'), {
    type: 'bar',
    data: { labels: repLabels, datasets: [
        { label: 'محصّل من العملاء', data: repCollected, backgroundColor: 'rgba(6,182,212,.7)', borderRadius: 4 },
        { label: 'مسلّم للإدارة',    data: repSubmitted, backgroundColor: 'rgba(16,185,129,.7)', borderRadius: 4 }
    ] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
});

function exportPDF() {
    html2pdf().set({margin:10,filename:'rep-collections.pdf',html2canvas:{scale:2},jsPDF:{orientation:'landscape',format:'a4'}})
              .from(document.querySelector('.page-content')).save();
}
</script>
}
