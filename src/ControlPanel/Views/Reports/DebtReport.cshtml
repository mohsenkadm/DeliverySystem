@{
    ViewData["Title"] = "تقرير الديون";
    var customers = ViewBag.Customers as System.Collections.IEnumerable;
}
<div class="page-header d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1"><i class="fas fa-hand-holding-usd me-2 text-danger"></i>تقرير الديون</h4>
        <p class="text-muted mb-0">إجمالي الديون المستحقة على العملاء مع إمكانية الفلترة والترتيب</p>
    </div>
    <div class="d-flex gap-2 no-print">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-print me-1"></i>طباعة</button>
        <button onclick="exportPDF()" class="btn btn-outline-danger btn-sm"><i class="fas fa-file-pdf me-1"></i>PDF</button>
    </div>
</div>

<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-1">الحد الأدنى للدين (ر.س)</label>
                <input type="number" name="minDebt" value="@ViewBag.MinDebt" step="0.01" min="0" class="form-control form-control-sm" placeholder="0" />
            </div>
            <div class="col-auto">
                <label class="form-label small mb-1">ترتيب حسب</label>
                <select name="sortBy" class="form-select form-select-sm">
                    <option value="debt" selected="@(ViewBag.SortBy=="debt")">المبلغ</option>
                    <option value="date" selected="@(ViewBag.SortBy=="date")">آخر فاتورة</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small mb-1">الاتجاه</label>
                <select name="sortDir" class="form-select form-select-sm">
                    <option value="desc" selected="@(ViewBag.SortDir=="desc")">تنازلي</option>
                    <option value="asc"  selected="@(ViewBag.SortDir=="asc")">تصاعدي</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i>تصفية</button>
                <a asp-action="DebtReport" class="btn btn-outline-secondary btn-sm">إعادة تعيين</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="stat-card card text-white bg-danger" data-aos="zoom-in">
            <div class="card-body text-center">
                <div class="stat-number">@((decimal)ViewBag.TotalDebt).ToString("N0")</div>
                <div class="stat-label">إجمالي الديون (ر.س)</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card card text-white bg-warning" data-aos="zoom-in" data-aos-delay="100">
            <div class="card-body text-center">
                <div class="stat-number">@(((System.Collections.IEnumerable)customers).Cast<object>().Count())</div>
                <div class="stat-label">عدد العملاء المدينين</div>
            </div>
        </div>
    </div>
</div>

<div class="card" data-aos="fade-up">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-table me-2"></i>قائمة الديون</span>
        <small class="text-muted">مرتّب @(ViewBag.SortBy=="debt"?"حسب المبلغ":"حسب التاريخ") — @(ViewBag.SortDir=="desc"?"تنازلي":"تصاعدي")</small>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>العميل</th>
                        <th>المتجر</th>
                        <th class="text-end">إجمالي الفواتير</th>
                        <th class="text-end">المدفوع</th>
                        <th class="text-end">الدين</th>
                        <th>آخر فاتورة</th>
                        <th class="no-print">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int r = 1; }
                    @foreach (dynamic c in customers ?? Enumerable.Empty<object>())
                    {
                        <tr>
                            <td>@r</td>
                            <td><strong>@c.FullName</strong><br/><small class="text-muted">@c.Phone</small></td>
                            <td>@(c.StoreName ?? "—")</td>
                            <td class="text-end">@c.TotalAmount.ToString("N2") ر.س</td>
                            <td class="text-end text-success">@c.PaidAmount.ToString("N2") ر.س</td>
                            <td class="text-end fw-bold text-danger">@c.Debt.ToString("N2") ر.س</td>
                            <td>@(c.LastInvoice?.ToString("yyyy/MM/dd") ?? "—")</td>
                            <td class="no-print">
                                <a asp-controller="Customers" asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                        r++;
                    }
                    @if (r == 1) { <tr><td colspan="8" class="text-center py-4 text-muted">لا توجد ديون مستحقة</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
function exportPDF() {
    html2pdf().set({ margin:10, filename:'debt-report.pdf', html2canvas:{scale:2}, jsPDF:{orientation:'landscape',format:'a4'} })
              .from(document.querySelector('.page-content')).save();
}
</script>
}
