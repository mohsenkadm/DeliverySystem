@{
    ViewData["Title"] = "تقرير المبيعات اليومية";
}
<div class="page-header d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1"><i class="fas fa-calendar-day me-2 text-primary"></i>المبيعات اليومية</h4>
        <p class="text-muted mb-0">إجمالي المبيعات لكل يوم خلال الفترة المحددة</p>
    </div>
    <div class="d-flex gap-2 no-print">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-print me-1"></i>طباعة</button>
        <button onclick="exportPDF()" class="btn btn-outline-danger btn-sm"><i class="fas fa-file-pdf me-1"></i>PDF</button>
    </div>
</div>

<!-- Filter -->
<div class="card mb-4 no-print" data-aos="fade-up">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-1">من</label>
                <input type="date" name="from" value="@ViewBag.From" class="form-control form-control-sm" />
            </div>
            <div class="col-auto">
                <label class="form-label small mb-1">إلى</label>
                <input type="date" name="to" value="@ViewBag.To" class="form-control form-control-sm" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>تصفية</button>
            </div>
        </form>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card card text-white bg-primary" data-aos="zoom-in">
            <div class="card-body text-center">
                <div class="stat-number">@(((decimal)ViewBag.GrandTotal).ToString("N0"))</div>
                <div class="stat-label">إجمالي المبيعات (د.ع)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card card text-white bg-success" data-aos="zoom-in" data-aos-delay="100">
            <div class="card-body text-center">
                <div class="stat-number">@(((List<int>)ViewBag.Counts).Sum())</div>
                <div class="stat-label">عدد الفواتير</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card card text-white bg-info" data-aos="zoom-in" data-aos-delay="200">
            <div class="card-body text-center">
                @{ var cnt = ((List<int>)ViewBag.Counts).Sum(); var total = (decimal)ViewBag.GrandTotal; }
                <div class="stat-number">@(cnt > 0 ? (total/cnt).ToString("N0") : "0")</div>
                <div class="stat-label">متوسط قيمة الفاتورة (د.ع)</div>
            </div>
        </div>
    </div>
</div>

<!-- Chart -->
<div class="card mb-4" data-aos="fade-up">
    <div class="card-header"><i class="fas fa-chart-bar me-2"></i>مخطط المبيعات اليومية</div>
    <div class="card-body"><div style="height:320px"><canvas id="dailyChart"></canvas></div></div>
</div>

<!-- Table -->
<div class="card" data-aos="fade-up">
    <div class="card-header"><i class="fas fa-table me-2"></i>تفاصيل يومية</div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>التاريخ</th><th class="text-center">عدد الفواتير</th><th class="text-end">إجمالي المبيعات</th></tr>
            </thead>
            <tbody>
                @{ var labels = (List<string>)ViewBag.Labels; var totals = (List<decimal>)ViewBag.Totals; var counts = (List<int>)ViewBag.Counts; }
                @for (int i = 0; i < labels.Count; i++)
                {
                    <tr>
                        <td>@labels[i]</td>
                        <td class="text-center">@counts[i]</td>
                        <td class="text-end fw-bold text-primary">@totals[i].ToString("N2") د.ع</td>
                    </tr>
                }
                @if (!labels.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">لا توجد بيانات للفترة المحددة</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Labels ?? new List<string>()));
const totals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Totals ?? new List<decimal>()));
const counts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Counts ?? new List<int>()));

new Chart(document.getElementById('dailyChart'), {
    type: 'bar',
    data: {
        labels,
        datasets: [
            { label: 'المبيعات (د.ع)', data: totals, backgroundColor: 'rgba(79,70,229,.7)', borderRadius: 5, yAxisID: 'y' },
            { label: 'عدد الفواتير', data: counts, backgroundColor: 'rgba(6,182,212,.5)', borderRadius: 5, type: 'line', yAxisID: 'y1' }
        ]
    },
    options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'top' } },
        scales: { y: { beginAtZero: true, position: 'right' }, y1: { beginAtZero: true, position: 'left', grid: { drawOnChartArea: false } }, x: { grid: { display: false } } }
    }
});

function exportPDF() {
    const el = document.querySelector('.page-content');
    html2pdf().set({ margin: 10, filename: 'daily-sales.pdf', html2canvas: { scale: 2 }, jsPDF: { orientation: 'portrait', format: 'a4' } }).from(el).save();
}
</script>
}
