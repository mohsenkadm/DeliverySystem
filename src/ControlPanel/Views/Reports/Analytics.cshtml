@{
    ViewData["Title"] = "تحليل البيانات";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-chart-bar"></i> تحليل البيانات</h1>
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm no-print"><i class="fas fa-print me-1"></i>طباعة</button>
</div>

<div class="row g-4">
    <!-- Monthly Sales -->
    <div class="col-xl-8" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-chart-line"></i> المبيعات الشهرية (آخر 12 شهر)</div>
            <div class="card-body"><div class="chart-container"><canvas id="monthlySalesChart"></canvas></div></div>
        </div>
    </div>
    <!-- Invoice Status -->
    <div class="col-xl-4" data-aos="fade-up" data-aos-delay="100">
        <div class="card">
            <div class="card-header"><i class="fas fa-chart-pie"></i> توزيع حالات الطلبات</div>
            <div class="card-body"><div class="chart-container"><canvas id="statusChart"></canvas></div></div>
        </div>
    </div>
    <!-- Top Customers -->
    <div class="col-xl-6" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-trophy"></i> أعلى 10 عملاء مبيعاً</div>
            <div class="card-body"><div class="chart-container"><canvas id="topCustomersChart"></canvas></div></div>
        </div>
    </div>
    <!-- Top Representatives -->
    <div class="col-xl-6" data-aos="fade-up" data-aos-delay="100">
        <div class="card">
            <div class="card-header"><i class="fas fa-user-tie"></i> أداء المندوبين</div>
            <div class="card-body"><div class="chart-container"><canvas id="repChart"></canvas></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const months  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Months  ?? new List<string>()));
const monthly = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Monthly ?? new List<decimal>()));
const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusLabels ?? new List<string>()));
const statusData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData   ?? new List<int>()));
const custLabels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopCustomerLabels ?? new List<string>()));
const custData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopCustomerData   ?? new List<decimal>()));
const repLabels    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepLabels ?? new List<string>()));
const repData      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RepData   ?? new List<decimal>()));

// Monthly Sales
new Chart(document.getElementById('monthlySalesChart'), {
    type: 'bar',
    data: { labels: months, datasets: [{ label: 'المبيعات (د.ع)', data: monthly, backgroundColor: 'rgba(79,70,229,.7)', borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
});

// Status Pie
new Chart(document.getElementById('statusChart'), {
    type: 'pie',
    data: { labels: statusLabels, datasets: [{ data: statusData, backgroundColor: ['#f59e0b','#10b981','#ef4444','#4f46e5','#06b6d4','#64748b'], borderWidth: 2 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { family: 'Cairo', size: 12 } } } } }
});

// Top Customers
new Chart(document.getElementById('topCustomersChart'), {
    type: 'horizontalBar' in Chart.controllers ? 'horizontalBar' : 'bar',
    data: { labels: custLabels, datasets: [{ label: 'المبيعات (د.ع)', data: custData, backgroundColor: 'rgba(6,182,212,.7)', borderRadius: 6 }] },
    options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
});

// Representatives
new Chart(document.getElementById('repChart'), {
    type: 'bar',
    data: { labels: repLabels, datasets: [{ label: 'المحصّل (د.ع)', data: repData, backgroundColor: 'rgba(16,185,129,.7)', borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
});
</script>
}
