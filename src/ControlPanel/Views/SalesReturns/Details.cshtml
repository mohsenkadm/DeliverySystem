@model DeliverySystem.Application.DTOs.SalesReturnDto
@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = $"مرتجع #{Model.Id}";
}
<div class="page-header mb-4" data-aos="fade-down">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    <h4><i class="fas fa-undo-alt me-2 text-danger"></i>طلب مرتجع #@Model.Id</h4>
</div>

<div class="row g-4">
    <div class="col-md-4" data-aos="fade-up">
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>معلومات الطلب</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">الفاتورة</dt><dd class="col-7">@(Model.InvoiceNumber ?? "—")</dd>
                    <dt class="col-5">طلبه</dt><dd class="col-7">@Model.RequestedByEmployeeName</dd>
                    <dt class="col-5">الحالة</dt>
                    <dd class="col-7">
                        @{ var bc = Model.Status switch { SalesReturnStatus.Pending=>"bg-warning text-dark", SalesReturnStatus.ManagerApproved=>"bg-info", SalesReturnStatus.WarehouseApproved=>"bg-secondary", SalesReturnStatus.AccountantApproved=>"bg-primary", SalesReturnStatus.Completed=>"bg-success", SalesReturnStatus.Rejected=>"bg-danger", _=>"bg-secondary" }; }
                        <span class="badge @bc">@Model.StatusText</span>
                    </dd>
                    <dt class="col-5">السبب</dt><dd class="col-7">@Model.Reason</dd>
                    @if (!string.IsNullOrEmpty(Model.Notes)) { <dt class="col-5">ملاحظات</dt><dd class="col-7">@Model.Notes</dd> }
                    <dt class="col-5">تاريخ الطلب</dt><dd class="col-7">@Model.RequestedAt.ToString("yyyy/MM/dd HH:mm")</dd>
                    @if (Model.ApprovedAt.HasValue) { <dt class="col-5">تاريخ الموافقة</dt><dd class="col-7">@Model.ApprovedAt.Value.ToString("yyyy/MM/dd")</dd> }
                    @if (Model.CompletedAt.HasValue) { <dt class="col-5">تاريخ الإكمال</dt><dd class="col-7">@Model.CompletedAt.Value.ToString("yyyy/MM/dd")</dd> }
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div class="card mb-3">
                <div class="card-header"><i class="fas fa-image me-2"></i>صورة المرتجع</div>
                <div class="card-body p-2">
                    <img src="@Model.PhotoPath" class="img-fluid rounded" alt="صورة المرتجع" />
                </div>
            </div>
        }

        <!-- Workflow Actions -->
        <div class="card no-print">
            <div class="card-header"><i class="fas fa-bolt me-2"></i>إجراءات</div>
            <div class="card-body d-grid gap-2">
                @if (Model.Status == SalesReturnStatus.Pending)
                {
                    <form asp-action="ApproveManager" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-success w-100" onclick="return confirm('موافقة المدير على المرتجع؟')">
                            <i class="fas fa-check me-1"></i>موافقة المدير
                        </button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="text" name="reason" class="form-control mb-2" placeholder="سبب الرفض..." />
                        <button class="btn btn-danger w-100"><i class="fas fa-times me-1"></i>رفض</button>
                    </form>
                }
                @if (Model.Status == SalesReturnStatus.ManagerApproved)
                {
                    <form asp-action="ApproveWarehouse" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-warning w-100" onclick="return confirm('موافقة المستودع؟')">
                            <i class="fas fa-warehouse me-1"></i>موافقة المستودع
                        </button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="text" name="reason" class="form-control mb-2" placeholder="سبب الرفض..." />
                        <button class="btn btn-danger w-100"><i class="fas fa-times me-1"></i>رفض</button>
                    </form>
                }
                @if (Model.Status == SalesReturnStatus.WarehouseApproved)
                {
                    <form asp-action="Complete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary w-100" onclick="return confirm('إكمال المرتجع وتحديث المخزون؟')">
                            <i class="fas fa-check-double me-1"></i>موافقة المحاسب وإكمال المرتجع
                        </button>
                    </form>
                }
                @if (Model.Status == SalesReturnStatus.Completed) { <div class="alert alert-success mb-0"><i class="fas fa-check-circle me-1"></i>اكتمل طلب المرتجع</div> }
                @if (Model.Status == SalesReturnStatus.Rejected)  { <div class="alert alert-danger mb-0"><i class="fas fa-times-circle me-1"></i>تم رفض الطلب</div> }
            </div>
        </div>
    </div>

    <div class="col-md-8" data-aos="fade-up">
        <div class="card">
            <div class="card-header"><i class="fas fa-boxes me-2"></i>الأصناف المرتجعة (@Model.Details.Count)</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="table-light"><tr><th>المنتج</th><th class="text-center">الكمية</th><th>ملاحظات</th></tr></thead>
                    <tbody>
                        @foreach (var d in Model.Details)
                        {
                            <tr>
                                <td>@d.ProductName</td>
                                <td class="text-center"><span class="badge bg-primary">@d.Quantity</span></td>
                                <td>@(d.Notes ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
