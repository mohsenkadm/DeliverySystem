@model IEnumerable<DeliverySystem.Application.DTOs.SalesReturnDto>
@using DeliverySystem.Domain.Enums
@{
    ViewData["Title"] = "طلبات المرتجعات";
}
<div class="page-header d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1"><i class="fas fa-undo-alt me-2 text-danger"></i>طلبات المرتجعات</h4>
        <p class="text-muted mb-0">إدارة طلبات مرتجع المبيعات وسير الموافقات</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm no-print">
        <i class="fas fa-plus me-1"></i>طلب مرتجع جديد
    </a>
</div>

<!-- Filter -->
<div class="card mb-3 no-print" data-aos="fade-up">
    <div class="card-body py-2">
        <div class="btn-group">
            <a asp-action="Index" class="btn btn-sm @(ViewBag.Status==null?"btn-primary":"btn-outline-primary")">الكل</a>
            <a asp-action="Index" asp-route-status="0" class="btn btn-sm @(ViewBag.Status==0?"btn-warning":"btn-outline-warning")">بانتظار الموافقة</a>
            <a asp-action="Index" asp-route-status="1" class="btn btn-sm @(ViewBag.Status==1?"btn-info":"btn-outline-info")">موافقة المدير</a>
            <a asp-action="Index" asp-route-status="2" class="btn btn-sm @(ViewBag.Status==2?"btn-secondary":"btn-outline-secondary")">موافقة المستودع</a>
            <a asp-action="Index" asp-route-status="4" class="btn btn-sm @(ViewBag.Status==4?"btn-success":"btn-outline-success")">مكتملة</a>
            <a asp-action="Index" asp-route-status="5" class="btn btn-sm @(ViewBag.Status==5?"btn-danger":"btn-outline-danger")">مرفوضة</a>
        </div>
    </div>
</div>

<div class="card" data-aos="fade-up">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>الفاتورة</th><th>طلبه</th><th>السبب</th><th>الحالة</th><th>تاريخ الطلب</th><th>إجراء</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var bc = r.Status switch {
                            SalesReturnStatus.Pending => "bg-warning text-dark",
                            SalesReturnStatus.ManagerApproved => "bg-info",
                            SalesReturnStatus.WarehouseApproved => "bg-secondary",
                            SalesReturnStatus.AccountantApproved => "bg-primary",
                            SalesReturnStatus.Completed => "bg-success",
                            SalesReturnStatus.Rejected => "bg-danger",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>@r.Id</td>
                            <td>@(r.InvoiceNumber != null ? Html.Raw($"<code>{r.InvoiceNumber}</code>") : Html.Raw("<span class='text-muted'>—</span>"))</td>
                            <td>@r.RequestedByEmployeeName</td>
                            <td class="text-truncate" style="max-width:200px">@r.Reason</td>
                            <td><span class="badge @bc">@r.StatusText</span></td>
                            <td>@r.RequestedAt.ToString("yyyy/MM/dd")</td>
                            <td><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a></td>
                        </tr>
                    }
                    @if (!Model.Any()) { <tr><td colspan="7" class="text-center py-4 text-muted">لا توجد طلبات مرتجعات</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
