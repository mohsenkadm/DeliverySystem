@model CreateProductDto
@using DeliverySystem.Application.DTOs
@{
    ViewData["Title"] = "إضافة منتج جديد";
    var cartonTypes = ViewBag.CartonTypes as List<string> ?? [];
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-plus-circle"></i> إضافة منتج جديد</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-4">

        <!-- ── بيانات المنتج الأساسية ── -->
        <div class="col-lg-8">
            <div class="card" data-aos="fade-up">
                <div class="card-header"><i class="fas fa-box me-2"></i>بيانات المنتج</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label">اسم المنتج <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="اسم المنتج" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label">التصنيف <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">-- اختر التصنيف --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var c in ViewBag.Categories)
                                    { <option value="@c.Id">@c.Name</option> }
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">الوصف</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="وصف المنتج"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── الأسعار ── -->
            <div class="card mt-4" data-aos="fade-up">
                <div class="card-header"><i class="fas fa-tags me-2"></i>الأسعار</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WholesalePrice" class="form-label">سعر الجملة</label>
                            <div class="input-group">
                                <input asp-for="WholesalePrice" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                                <span class="input-group-text">ر.س</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RetailPrice" class="form-label">سعر المفرق</label>
                            <div class="input-group">
                                <input asp-for="RetailPrice" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                                <span class="input-group-text">ر.س</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DiscountPercentage" class="form-label">نسبة الخصم %</label>
                            <div class="input-group">
                                <input asp-for="DiscountPercentage" type="number" step="0.01" min="0" max="100" class="form-control" placeholder="0" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── الكرتون والكميات ── -->
            <div class="card mt-4" data-aos="fade-up">
                <div class="card-header"><i class="fas fa-cubes me-2"></i>الكرتون ووحدة القياس</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CartonType" class="form-label">وحدة القياس / الكرتون</label>
                            <select asp-for="CartonType" class="form-select">
                                <option value="">-- اختر الوحدة --</option>
                                @foreach (var t in cartonTypes) { <option value="@t">@t</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BaseQuantity" class="form-label">الكمية في الوحدة</label>
                            <input asp-for="BaseQuantity" type="number" min="1" class="form-control" placeholder="عدد القطع في الكرتون" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── التواريخ ── -->
            <div class="card mt-4" data-aos="fade-up">
                <div class="card-header"><i class="fas fa-calendar-alt me-2"></i>تواريخ الإنتاج والانتهاء</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ProductionDate" class="form-label">تاريخ الإنتاج</label>
                            <input asp-for="ProductionDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpirationDate" class="form-label">تاريخ الانتهاء</label>
                            <input asp-for="ExpirationDate" type="date" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── الصورة والإجراءات ── -->
        <div class="col-lg-4">
            <div class="card" data-aos="fade-up">
                <div class="card-header"><i class="fas fa-image me-2"></i>صورة المنتج</div>
                <div class="card-body text-center">
                    <div id="productPreview" class="mb-3">
                        <div style="height:160px;background:#f8fafc;border:2px dashed #e2e8f0;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                            <div class="text-muted text-center">
                                <i class="fas fa-box fa-3x mb-2 d-block"></i>
                                <small>صورة المنتج</small>
                            </div>
                        </div>
                    </div>
                    <label class="btn btn-outline-primary btn-sm w-100">
                        <i class="fas fa-upload me-1"></i>رفع الصورة
                        <input type="file" name="image" accept="image/*" class="d-none" onchange="previewImg(this)" />
                    </label>
                </div>
            </div>
            <div class="card mt-4" data-aos="fade-up">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 mb-2"><i class="fas fa-save me-2"></i>حفظ المنتج</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">إلغاء</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
function previewImg(input) {
    if (!input.files || !input.files[0]) return;
    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('productPreview').innerHTML =
            `<img src="${e.target.result}" class="img-fluid rounded" style="max-height:160px;width:100%;object-fit:cover;" />`;
    };
    reader.readAsDataURL(input.files[0]);
}
</script>
}
