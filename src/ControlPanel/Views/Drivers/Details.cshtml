@model DriverDto
@{
    ViewData["Title"] = "تفاصيل السائق - " + Model.FullName;
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-car"></i> @Model.FullName</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm"><i class="fas fa-edit me-1"></i>تعديل</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4" data-aos="fade-up">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="avatar-circle mx-auto mb-3" style="width:80px;height:80px;font-size:32px;background:linear-gradient(135deg,#f59e0b,#ef4444)">
                    @Model.FullName.Substring(0,1)
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                @if (Model.IsActive)
                {
                    <span class="badge-status badge-accepted"><i class="fas fa-circle me-1" style="font-size:8px"></i>سائق نشط</span>
                }
                else
                {
                    <span class="badge-status badge-rejected">غير نشط</span>
                }
                <hr />
                <dl class="row text-start mb-0">
                    <dt class="col-5 text-muted"><i class="fas fa-phone me-1"></i>الهاتف</dt>
                    <dd class="col-7">@Model.Phone</dd>
                    <dt class="col-5 text-muted"><i class="fas fa-map-marker-alt me-1"></i>العنوان</dt>
                    <dd class="col-7">@(string.IsNullOrEmpty(Model.Address) ? "-" : Model.Address)</dd>
                    <dt class="col-5 text-muted"><i class="fas fa-user me-1"></i>اسم المستخدم</dt>
                    <dd class="col-7"><code>@Model.Username</code></dd>
                    <dt class="col-5 text-muted"><i class="fas fa-calendar me-1"></i>تاريخ التسجيل</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("yyyy/MM/dd")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-8" data-aos="fade-up" data-aos-delay="100">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card stat-card text-center py-3">
                    <div class="stat-value text-warning fs-2">@Model.ActiveDeliveries</div>
                    <div class="text-muted">توصيلات نشطة</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card stat-card text-center py-3">
                    <div class="stat-value text-success fs-2">@Model.CompletedDeliveries</div>
                    <div class="text-muted">توصيلات مكتملة</div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><i class="fas fa-info-circle"></i> معلومات إضافية</div>
            <div class="card-body">
                <p class="text-muted mb-0">إجمالي التوصيلات: <strong>@(Model.ActiveDeliveries + Model.CompletedDeliveries)</strong></p>
            </div>
        </div>
    </div>
</div>
