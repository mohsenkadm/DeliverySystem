@{
    ViewData["Title"] = "إضافة مستودع جديد";
}
<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-warehouse"></i> إضافة مستودع جديد</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card" data-aos="fade-up">
            <div class="card-header"><i class="fas fa-warehouse"></i> بيانات المستودع</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">اسم المستودع <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" placeholder="اسم المستودع" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الموقع</label>
                        <input name="Location" class="form-control" placeholder="الموقع أو العنوان" />
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>حفظ</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">إلغاء</a>
                </form>
            </div>
        </div>
    </div>
</div>
