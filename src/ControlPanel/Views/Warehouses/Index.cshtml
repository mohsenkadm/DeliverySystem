@model IEnumerable<WarehouseDto>
@{
    ViewData["Title"] = "إدارة المستودعات";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-warehouse"></i> إدارة المستودعات</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm no-print"><i class="fas fa-plus me-1"></i>إضافة مستودع</a>
</div>

<div class="row g-4">
    @foreach (var w in Model)
    {
        <div class="col-xl-4 col-md-6" data-aos="fade-up">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="avatar-circle" style="width:50px;height:50px;font-size:20px;background:linear-gradient(135deg,#10b981,#06b6d4)">
                            <i class="fas fa-warehouse" style="font-size:18px"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@w.Name</h5>
                            <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i>@(w.Location ?? "-")</small>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="text-center">
                            <div class="fw-bold text-primary fs-4">@w.ProductCount</div>
                            <small class="text-muted">منتج</small>
                        </div>
                        <div class="text-center">
                            <small class="text-muted">تاريخ الإنشاء</small><br>
                            <small>@w.CreatedAt.ToString("yyyy/MM/dd")</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-outline-warning btn-sm flex-fill"><i class="fas fa-edit me-1"></i>تعديل</a>
                        <form asp-action="Delete" asp-route-id="@w.Id" method="post" class="d-inline"
                              onsubmit="return confirm('حذف المستودع @w.Name؟')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger btn-action"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="fas fa-warehouse fa-3x mb-3 d-block opacity-25"></i>لا توجد مستودعات
        </div>
    }
</div>
