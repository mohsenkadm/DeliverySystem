@model EmployeeDto
@using DeliverySystem.Application.DTOs
@{
    ViewData["Title"] = "تفاصيل الموظف";
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-user-tie"></i> تفاصيل الموظف</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm no-print">
            <i class="fas fa-edit me-1"></i>تعديل
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm no-print">
            <i class="fas fa-arrow-right me-1"></i>العودة
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- بطاقة الملف الشخصي -->
    <div class="col-lg-4" data-aos="fade-up">
        <div class="card text-center">
            <div class="card-body py-4">
                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath" class="rounded-circle mb-3" style="width:110px;height:110px;object-fit:cover;border:4px solid #4f46e5;" alt="صورة الموظف" />
                }
                else
                {
                    <div class="avatar-circle mx-auto mb-3" style="width:110px;height:110px;font-size:42px;">@(Model.FullName.Length > 0 ? Model.FullName[0].ToString() : "م")</div>
                }
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted mb-2">@@@Model.Username</p>
                @{
                    var typeClass = Model.EmployeeType switch {
                        "Individual" => "bg-primary", "Representative" => "bg-success",
                        "Wholesale" => "bg-warning text-dark", _ => "bg-secondary"
                    };
                    var typeLabel = Model.EmployeeType switch {
                        "Individual" => "فرد", "Representative" => "مندوب",
                        "Wholesale" => "جملة", _ => Model.EmployeeType
                    };
                }
                <span class="badge @typeClass fs-6 mb-3">@typeLabel</span>
                <div>
                    @if (Model.IsActive)
                    { <span class="badge bg-success"><i class="fas fa-circle me-1"></i>نشط</span> }
                    else
                    { <span class="badge bg-danger"><i class="fas fa-circle me-1"></i>غير نشط</span> }
                </div>
            </div>
        </div>

        <!-- إحصائيات -->
        <div class="row g-3 mt-1">
            <div class="col-6">
                <div class="stat-card accent text-center py-3">
                    <div class="stat-value">@Model.CustomerCount</div>
                    <div class="stat-label">عملاء</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card success text-center py-3">
                    <div class="stat-value">@Model.CompletedDeliveries</div>
                    <div class="stat-label">توصيل مكتمل</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card warning text-center py-3">
                    <div class="stat-value">@Model.ActiveDeliveries</div>
                    <div class="stat-label">توصيل نشط</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card danger text-center py-3">
                    <div class="stat-value">@String.Format("{0:N0}", Model.TotalDebt) <small style="font-size:11px">ر.س</small></div>
                    <div class="stat-label">ديون</div>
                </div>
            </div>
        </div>
    </div>

    <!-- تفاصيل -->
    <div class="col-lg-8" data-aos="fade-up">
        <div class="card mb-4">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>المعلومات التفصيلية</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small">رقم الهاتف</label>
                        <div class="fw-bold"><i class="fas fa-phone text-primary me-2"></i>@Model.Phone</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">تاريخ الانضمام</label>
                        <div class="fw-bold"><i class="fas fa-calendar text-primary me-2"></i>@Model.CreatedAt.ToString("yyyy/MM/dd")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="col-12">
                            <label class="text-muted small">العنوان السكني</label>
                            <div class="fw-bold"><i class="fas fa-home text-primary me-2"></i>@Model.Address</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Region))
                    {
                        <div class="col-md-6">
                            <label class="text-muted small">المنطقة</label>
                            <div class="fw-bold"><i class="fas fa-map-marker-alt text-danger me-2"></i>@Model.Region</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Branch))
                    {
                        <div class="col-md-6">
                            <label class="text-muted small">الفرع</label>
                            <div class="fw-bold"><i class="fas fa-building text-info me-2"></i>@Model.Branch</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.CarNumber))
                    {
                        <div class="col-md-6">
                            <label class="text-muted small">رقم السيارة</label>
                            <div class="fw-bold"><i class="fas fa-car text-warning me-2"></i>@Model.CarNumber</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.CarType))
                    {
                        <div class="col-md-6">
                            <label class="text-muted small">نوع السيارة</label>
                            <div class="fw-bold"><i class="fas fa-car-side text-warning me-2"></i>@Model.CarType</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.RolesList.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-briefcase me-2"></i>الأدوار الوظيفية</div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var role in Model.RolesList)
                        {
                            <span class="badge bg-primary fs-6 px-3 py-2">@role</span>
                        }
                    </div>
                </div>
            </div>
        }

        @if (Model.AreasList.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-map me-2"></i>المناطق المعينة</div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var area in Model.AreasList)
                        {
                            <span class="badge bg-success fs-6 px-3 py-2"><i class="fas fa-map-marker-alt me-1"></i>@area</span>
                        }
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.IdImagePath))
        {
            <div class="card">
                <div class="card-header"><i class="fas fa-id-badge me-2"></i>صورة الهوية</div>
                <div class="card-body text-center">
                    <img src="@Model.IdImagePath" class="img-fluid rounded" style="max-height:200px;" alt="صورة الهوية" />
                </div>
            </div>
        }
    </div>
</div>
