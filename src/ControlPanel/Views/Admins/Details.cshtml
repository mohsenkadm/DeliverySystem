@model AdminDto
@{
    ViewData["Title"] = "تفاصيل المسؤول - " + Model.FullName;
}

<div class="page-header" data-aos="fade-down">
    <h1><i class="fas fa-user-shield"></i> @Model.FullName</h1>
    <div class="d-flex gap-2">
        <a asp-action="Permissions" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
            <i class="fas fa-key me-1"></i>إدارة الصلاحيات
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4" data-aos="fade-up">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="avatar-circle mx-auto mb-3" style="width:80px;height:80px;font-size:32px;background:linear-gradient(135deg,#4f46e5,#06b6d4)">
                    @Model.FullName.Substring(0, 1)
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                @if (Model.IsActive)
                {
                    <span class="badge-status badge-accepted"><i class="fas fa-circle me-1" style="font-size:8px"></i>نشط</span>
                }
                else
                {
                    <span class="badge-status badge-rejected">معطل</span>
                }
                <hr />
                <dl class="row text-start mb-0">
                    <dt class="col-5 text-muted">اسم المستخدم</dt>
                    <dd class="col-7"><code>@Model.Username</code></dd>
                    <dt class="col-5 text-muted">تاريخ الإنشاء</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("yyyy/MM/dd")</dd>
                    <dt class="col-5 text-muted">عدد الصلاحيات</dt>
                    <dd class="col-7"><span class="badge bg-primary">@Model.Permissions.Count</span></dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-8" data-aos="fade-up" data-aos-delay="100">
        <div class="card">
            <div class="card-header"><i class="fas fa-key"></i> الصلاحيات الممنوحة</div>
            <div class="card-body p-0">
                @if (Model.Permissions.Any())
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>الصفحة</th>
                                    <th class="text-center">عرض</th>
                                    <th class="text-center">إضافة</th>
                                    <th class="text-center">تعديل</th>
                                    <th class="text-center">حذف</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Permissions)
                                {
                                    <tr>
                                        <td><i class="fas fa-file-alt me-2 text-primary"></i>@p.PageName</td>
                                        <td class="text-center">@(p.CanView   ? "✅" : "—")</td>
                                        <td class="text-center">@(p.CanAdd    ? "✅" : "—")</td>
                                        <td class="text-center">@(p.CanEdit   ? "✅" : "—")</td>
                                        <td class="text-center">@(p.CanDelete ? "✅" : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-lock fa-2x mb-2 d-block opacity-25"></i>
                        لم يتم تحديد صلاحيات بعد
                        <div class="mt-2">
                            <a asp-action="Permissions" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-key me-1"></i>إضافة صلاحيات
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
